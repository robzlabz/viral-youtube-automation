generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[]
}

model Project {
  id           String       @id @default(cuid())
  slug         String       @unique
  title        String
  status       ProjectStatus @default(DRAFT)
  styleChoice  String?
  script       String?
  narrativeStyle String     @default("productivity")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  userId       String
  user         User         @relation(fields: [userId], references: [id])

  visualBible  VisualBible?
  scenes       Scene[]
  jobs         Job[]
  renderOutput RenderOutput?
}

enum ProjectStatus {
  DRAFT
  SCRIPT_DONE
  SCENES_DONE
  VOICES_DONE
  IMAGES_DONE
  RENDERING
  COMPLETE
}

model VisualBible {
  id                   String @id @default(cuid())
  characters           Json   @default("[]")
  environments         Json   @default("[]")
  colorPalette         Json   @default("[]")
  cameraLanguage       String @default("medium shot")
  negativeRules        Json   @default("[\"no text\", \"no watermark\", \"no typography\"]")
  styleAnchorTokens    String @default("")
  aspectRatio          String @default("16:9")

  projectId            String @unique
  project              Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Scene {
  id            String     @id @default(cuid())
  sceneIndex    Int
  text          String     @default("")
  imagePrompt   String     @default("")
  voiceFilePath String?
  voiceLength   Float?
  imageFilePath String?
  status        SceneStatus @default(PENDING)

  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([projectId, sceneIndex])
}

enum SceneStatus {
  PENDING
  VOICE_GENERATING
  VOICE_DONE
  IMAGE_GENERATING
  IMAGE_DONE
  COMPLETE
}

model Job {
  id          String    @id @default(cuid())
  type        JobType
  status      JobStatus @default(QUEUED)
  progressPct Int       @default(0)
  errorMsg    String?
  startedAt   DateTime?
  finishedAt  DateTime?

  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum JobType {
  VOICE_GEN
  IMAGE_GEN
  RENDER
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETE
  FAILED
}

model RenderOutput {
  id            String   @id @default(cuid())
  filepath      String
  durationSec   Float
  filesizeBytes Int
  createdAt     DateTime @default(now())

  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
